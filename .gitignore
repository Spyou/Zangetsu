# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Internal docs (plans, specs, audits) — not part of the shipped app
/docs/
# Built release APK artifacts (any version)
release-v*/
# Marketing/banner scratch (mockups, screenshots) — not part of the app
banner/
# Poster render scratch (build/render scripts, generated art) — not shipped
poster/
secrets.json

# Aniyomi loader test fixture APK — on-device validated instead of committed
android/app/src/test/resources/aniyomi/*.apk

# Supabase local env (service_role key is secret — never commit)
.env
.env.*
*.local
supabase/.env
