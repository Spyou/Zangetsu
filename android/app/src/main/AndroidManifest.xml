<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Network: Flutter only auto-adds INTERNET to debug builds, so it MUST be
         declared here or release builds have no network at all (streaming,
         providers, downloads). -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <!-- Download progress notification (Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- In-app update: install the downloaded APK via the system installer. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>
    <!-- Foreground service so HLS downloads continue in the background. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <!-- Saving player screenshots to the gallery (gal); Android 10+ needs none. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28"/>
    <!-- Android TV leanback: required=false so the app still installs on phones. -->
    <uses-feature android:name="android.software.leanback" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <application
        android:label="Zangetsu"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:banner="@drawable/tv_banner"
        android:enableOnBackInvokedCallback="true">
        <!-- flutter_background_service declares this service but without a
             foregroundServiceType, which Android 14+ requires for dataSync.
             Same attrs as the plugin + the type (merged, no conflict). -->
        <service
            android:name="id.flutter.flutter_background_service.BackgroundService"
            android:enabled="true"
            android:exported="true"
            android:stopWithTask="false"
            android:foregroundServiceType="dataSync" />
        <!-- Keeps the process alive for native torrent downloads (phase 2). -->
        <service
            android:name=".TorrentDownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:supportsPictureInPicture="true"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
            <!-- Tracker OAuth redirects (AniList / MyAnimeList / Simkl) sent back
                 to zangetsu://<host> and captured by app_links. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="zangetsu" android:host="anilist-auth"/>
                <data android:scheme="zangetsu" android:host="mal-auth"/>
                <data android:scheme="zangetsu" android:host="simkl-auth"/>
                <!-- Shared-title deep link: zangetsu://open?d=…&t=… (see OpenLinkService). -->
                <data android:scheme="zangetsu" android:host="open"/>
                <data android:scheme="zangetsu" android:host="room"/>
            </intent-filter>
        </activity>
        <!-- Hosts a CloudStream plugin's own settings UI (it casts the Context to
             AppCompatActivity and shows a BottomSheetDialogFragment). Transparent
             Material theme; finishes when the sheet is dismissed. -->
        <activity
            android:name=".cloudstream.CloudStreamSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.CloudStreamSettings"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode" />
        <!-- Hosts an Aniyomi extension's ConfigurableAnimeSource settings UI via a
             PreferenceFragmentCompat. Launched by AniyomiBridge.openSourceSettings. -->
        <activity
            android:name=".aniyomi.AniyomiSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.AniyomiSettings"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode" />
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- External video players we can hand a stream to (package visibility
             on Android 11+). -->
        <package android:name="com.mxtech.videoplayer.ad"/>
        <package android:name="com.mxtech.videoplayer.pro"/>
        <package android:name="org.videolan.vlc"/>
        <package android:name="is.xyz.mpv"/>
        <package android:name="com.brouken.player"/>
        <package android:name="dev.anilbeesetti.nextplayer"/>
    </queries>
</manifest>
